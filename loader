local function runLoading()
    loadingFill.Size = UDim2.new(0, 0, 1, 0)
    percentLabel.Text = "0%"

    for i = 0, 100 do
        loadingFill.Size = UDim2.new(i / 100, 0, 1, 0)
        percentLabel.Text = i .. "%"
        task.wait(0.02)
    end
end

