local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

pcall(function()
    if CoreGui:FindFirstChild("LightHubVisualLoader") then
        CoreGui.LightHubVisualLoader:Destroy()
    end
end)

local gui = Instance.new("ScreenGui")
gui.Name = "LightHubVisualLoader"
gui.Parent = CoreGui
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false

-- COLORS
local BG = Color3.fromRGB(10,10,12)
local CARD = Color3.fromRGB(19,19,23)
local PANEL = Color3.fromRGB(24,24,28)
local THEME = Color3.fromRGB(255,255,0)
local THEME_SOFT = Color3.fromRGB(255,230,120)
local WHITE = Color3.fromRGB(245,245,245)
local DIM = Color3.fromRGB(38,22,12)

local function round(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0,r)
    c.Parent = obj
end

local function stroke(obj, color, thickness, transparency)
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = thickness
    s.Transparency = transparency or 0
    s.Parent = obj
end

local function tween(obj, time, props)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props):Play()
end

-- BACKGROUND
