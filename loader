-- LOADING ANIMATION
local running = true
task.spawn(function()
    local totalDuration = 10 -- seconds for demo
    local startTime = os.clock()
    while running do
        local elapsed = os.clock()-startTime
        local progress = math.clamp(elapsed/totalDuration,0,1)
        barFill.Size = UDim2.new(progress,0,1,0)
        percent.Text = math.floor(progress*100).."%"
        for i,mod in ipairs(moduleFrames) do
            if progress*100 > i*30 then
                mod.status.Text = "Active"
                mod.fill.Size = UDim2.new(1,0,1,0)
            else
                mod.status.Text = "Loading"
                mod.fill.Size = UDim2.new(progress,0,1,0)
            end
        end
        if elapsed>=totalDuration then break end
        task.wait(0.03)
    end
    running = false
    percent.Text = "100%"
end)
