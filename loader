local contentObjects = {}

local function makeToggle(text, y)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.9, 0, 0, 30)
    container.Position = UDim2.new(0.05, 0, 0, y)
    container.BackgroundTransparency = 1
    container.Parent = mainFrame
    table.insert(contentObjects, container)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -45, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = TextWhite
    label.TextSize = 11
    label.Font = Enum.Font.GothamMedium
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 38, 0, 20)
    btn.Position = UDim2.new(1, -38, 0.5, -10)
    btn.BackgroundColor3 = Grey
    btn.Text = ""
    btn.Parent = container
    corner(btn, 50)

    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 14, 0, 14)
    dot.Position = UDim2.new(0, 3, 0.5, -7)
    dot.BackgroundColor3 = TextWhite
    dot.Parent = btn
    corner(dot, 50)

    local active = false

    btn.MouseButton1Click:Connect(function()
        active = not active

        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = active and ThemeColor or Grey
        }):Play()

        TweenService:Create(dot, TweenInfo.new(0.15), {
            Position = active and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
        }):Play()
    end)
end

